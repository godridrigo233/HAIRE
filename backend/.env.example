# ==========================================================================
# Configuración del backend Haire — copiar a `.env` y rellenar con valores reales.
# NUNCA commitear el archivo `.env` con valores reales (ya está en .gitignore).
# ==========================================================================

# --- Base de datos (Postgres de Supabase) ---
# Se obtiene en Supabase > Connect (botón arriba) > ORMs/psql.
#
# EN LOCAL puedes usar la "Direct connection":
#   postgresql+psycopg://postgres:<PASSWORD>@db.cojqmblfaadoaywquiad.supabase.co:5432/postgres
#
# EN RENDER (y cualquier host solo-IPv4) la conexión directa FALLA (Supabase directo es
# IPv6). Usa el "Session pooler" (IPv4, puerto 5432). Ojo a dos detalles al copiarlo:
#   1) el usuario es  postgres.cojqmblfaadoaywquiad  (con el project-ref), no solo "postgres"
#   2) cambia el prefijo  postgresql://  ->  postgresql+psycopg://
# Formato del Session pooler (el <REGION> lo da Supabase, p.ej. us-east-1):
#   postgresql+psycopg://postgres.cojqmblfaadoaywquiad:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+psycopg://postgres:TU_PASSWORD@db.cojqmblfaadoaywquiad.supabase.co:5432/postgres

# --- Supabase Storage (para subir los PDFs al bucket privado `cv`) ---
SUPABASE_URL=https://cojqmblfaadoaywquiad.supabase.co
# service_role key (NO la anon). Supabase > Project Settings > API > service_role.
# Se usa solo en el backend; nunca exponer al frontend.
SUPABASE_SERVICE_KEY=TU_SERVICE_ROLE_KEY
SUPABASE_BUCKET=cv

# --- Groq (IA) ---
GROQ_API_KEY=TU_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# --- JWT (auth) ---
# Generar un secreto largo y aleatorio, p.ej.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- Auth interina (ver nota en README: la tabla `usuarios` no tiene columna de password) ---
# Password compartida de demo. El login valida que el correo exista en `usuarios`
# y que la password coincida con esta. Reemplazar por hashing real por usuario más adelante.
AUTH_DEMO_PASSWORD=haire2026

# --- CORS: orígenes del frontend permitidos (separados por coma) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
